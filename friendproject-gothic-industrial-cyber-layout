}

/* Video/embedded content */
embed, object, iframe {
    border: 2px solid #8a2be2;
    box-shadow: 0 0 20px rgba(138, 43, 226, 0.5);
    max-width: 100%;
}

/* Selection highlight */
::selection {
    background: #d946ff;
    color: #000000;
    text-shadow: none;
}

::-moz-selection {
    background: #d946ff;
    color: #000000;
    text-shadow: none;
}

